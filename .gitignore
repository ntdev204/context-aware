# ── Python ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/
*.egg-info/
dist/
build/

# ── Virtual environments ────────────────────────────────────────────
.venv/
venv/

# ── Model binaries (lớn, mount qua volume) ─────────────────────────
models/*.engine
models/*.pt
models/*.onnx
models/**/*.engine
models/**/*.pt
models/**/*.onnx

# ── Experience logs ─────────────────────────────────────────────────
logs/
*.h5
*.hdf5

# ── IDE ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# ── Generated proto ─────────────────────────────────────────────────
src/communication/proto/*_pb2*.py

# ── Env / secrets (contains IP, SSH key paths — never commit) ─────────
env/sync.env

# ── Research data (raw runs — large, machine-specific) ────────────────
# Ignore raw per-run folders (config, env, metrics, artifacts)
research_data/*/
# But DO track the generated aggregate CSVs and README index
!research_data/aggregated/
!research_data/README.md

# ── Agents ────────────────────────────────────────────────────────────
.agent/

# ── Dataset (bỏ qua 200GB+ để push code lên GitHub) ────────────────
dataset/intent_dataset/
roi_dataset/